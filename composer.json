{
    "name": "daniel-km/omeka-s-module-urify",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Check and convert literal values to normalized uri managed via Value Suggest, for example IdRef.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "administration",
        "curation"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-Urify",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-Urify/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.0",
        "daniel-km/omeka-s-module-common": "*"
    },
    "require": {
        "openspout/openspout": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Urify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UrifyTest\\": "tests/UrifyTest/"
        }
    },
    "config": {
        "platform": {
            "php": "7.4"
        }
    },
    "extra": {
        "installer-name": "Urify"
    }
}
